{
  "respectGitignore": true,
  "alwaysThinkingEnabled": true,
  "plansDirectory": "./plans",
  "showTurnDuration": true,
  "statusLine": {
    "type": "command",
    "command": "uv run python3 ~/.claude/statusline.py"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(date*)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git fetch*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash list*)",
      "Bash(git stash show*)",
      "Bash(git blame*)",
      "Bash(git remote*)",
      "Bash(git rev-parse*)",
      "Bash(git merge-base*)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh project *)",
      "Bash(gh api *)",
      "Bash(gh repo view*)",
      "Bash(gh label *)",
      "Bash(gh run *)",
      "Bash(uv run *)",
      "Bash(uv add *)",
      "Bash(uv sync*)",
      "Bash(az repos *)",
      "Bash(az pipelines *)",
      "Bash(gwm *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(actionlint*)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(env *)",
      "Bash(tree *)",
      "Bash(file *)",
      "Bash(realpath *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(gemini *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)",
      "Bash(> /dev/*)",
      "Bash(dd if=*)",
      "Bash(mkfs*)"
    ]
  }
}
